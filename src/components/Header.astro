---
import { site, nav } from "../data/site";
const path = Astro.url.pathname;
const isActive = (href) => (href === "/" ? path === "/" : path.startsWith(href));
---
<header class="sticky top-0 z-40 bg-sage-400/95 backdrop-blur supports-[backdrop-filter]:bg-sage-400/90 border-b border-sage-500/40">
  <div class="container-prose flex items-center justify-between h-16">
    <a href="/" class="font-serif text-2xl font-bold text-navy-900 tracking-tight" aria-label={`${site.name} — inicio`}>
      LRL
    </a>

    <nav class="hidden md:flex items-center gap-6" aria-label="Principal">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={["text-sm font-medium text-navy-900 hover:text-navy-700 transition", isActive(item.href) && "underline underline-offset-8 decoration-2"]}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden md:flex items-center gap-3">
      <a href={site.clientPortalUrl} target="_blank" rel="noopener" class="text-sm font-medium text-navy-900 px-3 py-2 rounded-full border border-navy-900/30 hover:bg-navy-900 hover:text-white transition">
        Acceso clientes
      </a>
      <a href="/contacto" class="text-sm font-semibold bg-navy-900 text-white px-4 py-2 rounded-full hover:bg-navy-800 transition">
        Consúltanos
      </a>
    </div>

    <button id="menu-toggle" class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded text-navy-900" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>

  <div id="mobile-menu" hidden class="md:hidden border-t border-sage-500/40 bg-sage-400">
    <nav class="container-prose py-4 flex flex-col gap-1" aria-label="Principal móvil">
      {nav.map((item) => (
        <a href={item.href} class="py-2 text-navy-900 font-medium" aria-current={isActive(item.href) ? "page" : undefined}>{item.label}</a>
      ))}
      <a href={site.clientPortalUrl} target="_blank" rel="noopener" class="py-2 text-navy-900 font-medium">Acceso clientes</a>
      <a href="/contacto" class="mt-2 text-center font-semibold bg-navy-900 text-white px-4 py-2 rounded-full">Consúltanos</a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const open = menu?.hasAttribute("hidden");
    if (open) { menu?.removeAttribute("hidden"); btn?.setAttribute("aria-expanded", "true"); btn?.setAttribute("aria-label", "Cerrar menú"); }
    else { menu?.setAttribute("hidden", ""); btn?.setAttribute("aria-expanded", "false"); btn?.setAttribute("aria-label", "Abrir menú"); }
  });
</script>
