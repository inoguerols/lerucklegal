  target="_blank"
  rel="noopener"
  class="fixed bottom-5 right-5 z-40 inline-flex items-center gap-2 bg-[#25D366] text-white font-semibold px-4 py-3 rounded-full shadow-lg hover:brightness-95 transition"
  aria-label="Contactar por WhatsApp"
>
