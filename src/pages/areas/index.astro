---
import Base from "../../layouts/Base.astro";
import { site, areas } from "../../data/site";
const title = `Áreas de práctica — ${site.name}`;
---
<Base title={title} description="Áreas de práctica en derecho tributario: inspecciones fiscales, recursos administrativos, contencioso-administrativo y planificación fiscal.">
  <section class="bg-navy-900 text-white">
    <div class="container-prose py-20 max-w-3xl">
      <p class="text-sage-200 uppercase tracking-wide text-sm font-medium">Áreas de práctica</p>
      <h1 class="font-serif text-4xl md:text-5xl mt-3">Especialización completa en fiscalidad y litigios tributarios</h1>
    </div>
  </section>
  <section class="container-prose py-16 md:py-20">
    <div class="grid gap-6 md:grid-cols-2">
      {areas.map((a) => (
        <a href={`/areas/${a.slug}`} class="block bg-white rounded-2xl p-7 border border-sage-200 hover:border-sage-400 hover:shadow-md transition">
          <h2 class="font-serif text-2xl text-navy-900">{a.title}</h2>
          <p class="mt-3 text-navy-800">{a.summary}</p>
          <span class="mt-4 inline-block text-sage-600 font-semibold">Ver detalle →</span>
        </a>
      ))}
    </div>
  </section>
</Base>
