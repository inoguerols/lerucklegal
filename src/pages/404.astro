---
import Base from "../layouts/Base.astro";
---
<Base title="Página no encontrada — Le Ruck Legal" noindex={true}>
  <section class="container-prose py-28 text-center">
    <p class="font-serif text-6xl text-sage-400">404</p>
    <h1 class="font-serif text-3xl text-navy-900 mt-4">Esta página no existe</h1>
    <p class="mt-4 text-navy-800">Puede que el enlace haya cambiado. Vuelve al inicio o contáctanos.</p>
    <div class="mt-8 flex gap-3 justify-center">
      <a href="/" class="bg-navy-900 text-white font-semibold px-6 py-3 rounded-full hover:bg-navy-800">Ir al inicio</a>
      <a href="/contacto" class="border border-navy-900/30 text-navy-900 font-semibold px-6 py-3 rounded-full hover:bg-cream">Contacto</a>
    </div>
  </section>
</Base>
