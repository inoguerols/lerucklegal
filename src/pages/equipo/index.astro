---
import Base from "../../layouts/Base.astro";
import { site, team } from "../../data/site";
const title = `Equipo — ${site.name}`;
---
<Base title={title} description="Abogados colegiados especializados en derecho tributario en Madrid.">
  <section class="bg-navy-900 text-white">
    <div class="container-prose py-20 max-w-3xl">
      <p data-reveal class="text-sage-200 uppercase tracking-wide text-sm font-medium">Equipo</p>
      <h1 data-reveal data-reveal-delay="1" class="font-serif text-4xl md:text-5xl mt-3">Abogados con nombre y apellidos</h1>
      <p data-reveal data-reveal-delay="2" class="mt-5 text-lg text-sage-100">Colegiados en el {site.legal.colegio} y especializados en fiscalidad.</p>
    </div>
  </section>
  <section class="container-prose py-16 md:py-20">
    <div class="grid gap-8 sm:grid-cols-2">
      {team.map((m, i) => (
        <a href={`/equipo/${m.slug}`} data-reveal data-reveal-delay={String((i % 2) + 1)} class="card-lift group block bg-white rounded-2xl border border-sage-200 hover:shadow-lg hover:border-sage-400">
          <div class="photo-zoom rounded-t-2xl">
            <img src={m.photo} alt={`Foto de ${m.name}`} width="600" height="600" loading="lazy" decoding="async" class="w-full aspect-square object-cover bg-sage-100" />
          </div>
          <div class="p-6">
            <h2 class="font-serif text-xl text-navy-900">{m.name}</h2>
            <p class="text-sage-600 font-medium text-sm mt-1">{m.role}</p>
            <p class="text-navy-800 text-sm mt-1">{m.colegiado}</p>
            <span class="mt-3 inline-block text-sage-600 font-medium group-hover:text-navy-900">Ver perfil →</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>
