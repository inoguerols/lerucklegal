---
import Base from "../layouts/Base.astro";
import JsonLd from "../components/JsonLd.astro";
import { site, areas, stats, team, faqs } from "../data/site";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---
<Base>
  <!-- HERO. TODO: sustituir el degradado por una foto real de rugby (scrum) en /hero.jpg -->
  <section class="relative text-white" style="background-image: linear-gradient(rgba(15,27,45,0.86), rgba(15,27,45,0.94)), url('/hero.jpg'); background-size: cover; background-position: center;">
    <div class="container-prose py-24 md:py-32 text-center">
      <p class="text-sage-200 font-medium tracking-wide uppercase text-sm">Abogados tributaristas · Madrid</p>
      <h1 class="font-serif text-4xl md:text-6xl font-bold mt-4 leading-tight">
        Defensa frente a Hacienda,<br class="hidden md:block" /> con anticipación y rigor
      </h1>
      <p class="mt-6 text-lg md:text-xl text-sage-100 max-w-2xl mx-auto">
        Despacho boutique especializado en <strong class="text-white">derecho tributario</strong>:
        inspecciones fiscales, recursos, litigios contencioso-administrativos y planificación fiscal.
      </p>
      <div class="mt-9 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/contacto" class="bg-sage-400 text-navy-900 font-semibold px-7 py-3 rounded-full hover:bg-sage-200 transition">Solicita una consulta confidencial</a>
        <a href="/areas" class="border border-white/40 text-white font-semibold px-7 py-3 rounded-full hover:bg-white/10 transition">Ver áreas de práctica</a>
      </div>
      <p class="mt-6 text-sm text-sage-200">Trabajo en equipo, honestidad y eficiencia.</p>
    </div>
  </section>

  <!-- BANDA DE CONFIANZA -->
  <section class="bg-cream border-y border-sage-200">
    <div class="container-prose py-10 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      {stats.map((s) => (
        <div>
          <p class="font-serif text-3xl md:text-4xl font-bold text-navy-900">{s.value}</p>
          <p class="text-sm text-navy-800 mt-1">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- INTRO -->
  <section class="container-prose py-16 md:py-20 max-w-3xl">
    <h2 class="font-serif text-3xl md:text-4xl text-navy-900">Especialistas en derecho tributario</h2>
    <p class="mt-5 text-lg text-navy-800 leading-relaxed">
      En {site.name} aplicamos los valores que dan nombre al despacho —el <em>ruck</em> del rugby:
      empuje coordinado, disciplina y trabajo en equipo— a la defensa de tus derechos como contribuyente.
      Nos dedicamos <strong>en exclusiva a la fiscalidad</strong>, anticipando los riesgos y construyendo
      la estrategia más sólida en cada fase del procedimiento.
    </p>
    <div class="mt-7 flex flex-wrap gap-3">
      <a href="/despacho" class="text-sage-600 font-semibold underline underline-offset-4 hover:text-navy-900">Conoce el despacho →</a>
    </div>
  </section>

  <!-- ÁREAS -->
  <section class="bg-cream">
    <div class="container-prose py-16 md:py-20">
      <h2 class="font-serif text-3xl md:text-4xl text-navy-900 text-center">Áreas de práctica</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {areas.map((a) => (
          <a href={`/areas/${a.slug}`} class="block bg-white rounded-2xl p-7 border border-sage-200 hover:border-sage-400 hover:shadow-md transition">
            <h3 class="font-serif text-xl text-navy-900">{a.title}</h3>
            <p class="mt-2 text-navy-800">{a.short}</p>
            <span class="mt-4 inline-block text-sage-600 font-medium">Ver más →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- EQUIPO TEASER -->
  <section class="container-prose py-16 md:py-20">
    <div class="md:flex md:items-end md:justify-between">
      <div class="max-w-xl">
        <h2 class="font-serif text-3xl md:text-4xl text-navy-900">Un equipo con nombre y apellidos</h2>
        <p class="mt-4 text-navy-800">Detrás de cada caso hay abogados colegiados en el {site.legal.colegio}, especializados en derecho tributario y comprometidos con tu defensa.</p>
      </div>
      <a href="/equipo" class="inline-block mt-6 md:mt-0 text-sage-600 font-semibold underline underline-offset-4 hover:text-navy-900">Conoce al equipo →</a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-cream">
    <div class="container-prose py-16 md:py-20 max-w-3xl">
      <h2 class="font-serif text-3xl md:text-4xl text-navy-900 text-center">Preguntas frecuentes</h2>
      <div class="mt-10 space-y-4">
        {faqs.map((f) => (
          <details class="bg-white rounded-xl border border-sage-200 p-5">
            <summary class="font-semibold text-navy-900 cursor-pointer">{f.q}</summary>
            <p class="mt-3 text-navy-800">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="bg-navy-900 text-white">
    <div class="container-prose py-16 text-center">
      <h2 class="font-serif text-3xl md:text-4xl">¿Tienes un problema con Hacienda?</h2>
      <p class="mt-4 text-sage-100 max-w-xl mx-auto">La primera consulta es confidencial y sin compromiso. Cuéntanos tu caso y te diremos cómo podemos ayudarte.</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/contacto" class="bg-sage-400 text-navy-900 font-semibold px-7 py-3 rounded-full hover:bg-sage-200 transition">Solicitar consulta</a>
        <a href={`tel:${site.phoneHref}`} class="border border-white/40 text-white font-semibold px-7 py-3 rounded-full hover:bg-white/10 transition">Llamar: {site.phone}</a>
      </div>
    </div>
  </section>

  <JsonLd schema={faqSchema} />
</Base>
